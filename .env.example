# Aphydle environment configuration
# Copy this file to `.env` and fill in real values for local dev.
# Variables prefixed with VITE_ are exposed to the client bundle.
#
# NOTE: When Aphydle is deployed as part of the Aphylia host stack, this
# file is replaced by the host's deploy tooling at build time. Anything
# set here only affects standalone / local dev — do not rely on these
# values in the embedded build.

# Supabase project credentials.
# Find these in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: base path when hosted as a sub-route. When Aphydle is embedded
# into the Aphylia host it is normally served from its own subdomain
# (aphydle.<primary>) with base "/", so this stays "/" in that setup.
VITE_APP_BASE_PATH=/

# Optional: origin of the Aphylia host API. When set, Aphydle may call
# back into the host (e.g. to record game results into the shared
# backend). Leave empty to keep Aphydle fully standalone (Supabase-only).
# Example: VITE_APHYLIA_API_URL=https://api.aphylia.app
VITE_APHYLIA_API_URL=

# Optional: URL to navigate users back to the Aphylia host from the
# Aphydle UI. Rendered in the footer as a "← back to Aphylia" link
# when set. Defaults to the public Aphylia site if unset.
# Example: VITE_APHYLIA_HOST_URL=https://aphylia.app
VITE_APHYLIA_HOST_URL=

# Canonical public URL of this Aphydle deploy. Used to generate the
# canonical <link>, OpenGraph/Twitter URLs, JSON-LD identifiers, the
# robots.txt Sitemap directive, and the absolute <loc> entries in
# sitemap.xml. No trailing slash. Falls back to https://aphydle.aphylia.com
# when unset, which is fine for dev but should be overridden in prod.
# Example: VITE_APP_SITE_URL=https://aphydle.aphylia.com
VITE_APP_SITE_URL=

# Optional: absolute URL of the social-share image (1200x630 recommended).
# Used for og:image and twitter:image. Defaults to "${VITE_APP_SITE_URL}/og-image.png"
# — drop a real PNG at that path in the served bundle to enable rich link
# previews on Twitter/X, Slack, Discord, iMessage, etc.
# Example: VITE_APP_OG_IMAGE=https://cdn.aphylia.com/aphydle/og.png
VITE_APP_OG_IMAGE=
